generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String

  saved     SavedCollege[]

  createdAt DateTime @default(now())
}

model College {
  id         String   @id @default(cuid())
  name       String
  location   String
  fees       Int
  rating     Float
  placements String
  overview   String

  reviews    Review[]
  savedBy    SavedCollege[]

  createdAt  DateTime @default(now())
}

model Review {
  id          String   @id @default(cuid())
  studentName String
  comment     String
  rating      Float

  collegeId   String
  college     College @relation(fields: [collegeId], references: [id])

  createdAt   DateTime @default(now())
}

model SavedCollege {
  id        String   @id @default(cuid())

  userId    String
  collegeId String

  user      User     @relation(fields: [userId], references: [id])
  college   College  @relation(fields: [collegeId], references: [id])

  createdAt DateTime @default(now())
}